{
  "name": "ecopass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "predev": "react-dsfr update-icons",
    "prebuild": "pnpm prisma:generate && react-dsfr update-icons && pnpm ecobalyse:data",
    "prisma:generate": "prisma generate",
    "queue:watch": "tsx watch ./queue.ts",
    "queue": "tsx ./queue.ts",
    "test": "jest && playwright test",
    "ecobalyse:data": "tsx src/scripts/decryptEcobalyseData.ts",
    "reset:test": "DATABASE_URL=postgresql://ecopass_test:ecopass_test@localhost:5433/ecopass_test pnpm prisma migrate reset --force",
    "preinstall": "pnpm dlx only-allow pnpm"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "11.x"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@codegouvfr/react-dsfr": "^1.32.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@socialgouv/matomo-next": "^1.13.1",
    "@types/jsdom": "^28.0.2",
    "@types/xlsx": "^0.0.36",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "chardet": "^2.1.1",
    "classnames": "^2.5.1",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "fuse.js": "^7.3.0",
    "helmet": "^8.1.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.7",
    "object-hash": "^3.0.0",
    "pg": "^8.16.0",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "swagger-ui-react": "^5.32.5",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "uuid": "^14.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^10.4.0",
